# Copy to .env (docker compose reads .env automatically). Do NOT commit .env.

# Django
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
CSRF_TRUSTED_ORIGINS=http://localhost:8080

# Postgres
POSTGRES_DB=smartnsales
POSTGRES_USER=smartnsales
POSTGRES_PASSWORD=smartnsales
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT / auth cookies
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=Lax

# Frontend (NEXT_PUBLIC_* is baked into the client bundle at build time)
NEXT_PUBLIC_API_URL=/api
INTERNAL_API_URL=http://backend:8000

# Seed demo data on backend boot (demo / demo12345)
SEED_ON_START=true
